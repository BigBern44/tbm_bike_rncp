# Clé API du flux GBFS TBM — OPTIONNEL.
# Flux Bordeaux Métropole en open data : si vide, la clé publique
# "opendata-bordeaux-metropole-flux-gtfs-rt" est utilisée par défaut.
GBFS_API_KEY=

# MinIO (stockage objet S3-compatible, couche bronze)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=lake
MINIO_USE_SSL=false

# Fichier DuckDB utilisé par dbt (silver/gold)
DUCKDB_PATH=velos.duckdb
